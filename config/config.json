{
  "training": {
    "sft": {
      "max_steps": 300,
      "batch_size": 4,
      "learning_rate": 2e-5,
      "gradient_accumulation_steps": 4
    },
    "grpo": {
      "max_steps": 100,
      "num_generations": 4,
      "learning_rate": 5e-6,
      "gradient_accumulation_steps": 4
    }
  },
  "simulation": {
    "parallel_workers": 12,
    "warmup_steps": 300,
    "max_rou_files": 12,
    "time_ranges": [
      {
        "start": "07:00",
        "end": "09:00"
      },
      {
        "start": "11:00",
        "end": "13:00"
      },
      {
        "start": "17:00",
        "end": "19:00"
      }
    ]
  },
  "rewards": {
    "format_weight": 0.2,
    "simulation_weight": 0.8
  },
  "paths": {
    "data_dir": "data/training",
    "sft_output": "outputs/sft",
    "grpo_output": "outputs/grpo",
    "net_file": "sumo_simulation/environments/chengdu/chengdu.net.xml",
    "sumocfg": "sumo_simulation/environments/chengdu/chengdu.sumocfg"
  }
}