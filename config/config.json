{
  "training": {
    "sft": {
      "model": {
        "model_name": "unsloth/Qwen3-4B-Base",
        "max_seq_length": 2048,
        "lora_rank": 32,
        "lora_alpha": 64,
        "load_in_4bit": false,
        "gpu_memory_utilization": 0.9,
        "target_modules": [
          "q_proj",
          "k_proj",
          "v_proj",
          "o_proj",
          "gate_proj",
          "up_proj",
          "down_proj"
        ]
      },
      "max_steps": 200,
      "num_train_epochs": 2,
      "dataset_text_field": "text",
      "per_device_train_batch_size": 1,
      "gradient_accumulation_steps": 1,
      "warmup_steps": 5,
      "learning_rate": 2e-4,
      "lr_scheduler_type": "linear",
      "optim": "adamw_8bit",
      "weight_decay": 0.001,
      "bf16": true,
      "logging_steps": 5,
      "save_steps": 100,
      "save_total_limit": 3,
      "seed": 3407,
      "report_to": "none"
    }
  },
  "simulation": {
    "parallel_workers": 16,
    "warmup_steps": 300,
    "max_rou_files": 1,
    "sim_duration": 3600
  },
  "paths": {
    "data_dir": "data/training",
    "sft_data_dir": "outputs/sft",
    "sft_output": "outputs/sft/model",
    "environments_dir": "sumo_simulation/environments"
  }
}